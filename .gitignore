# ============================================================
# Python / 字节码 / 缓存
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# 打包与发布
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# ============================================================
# 虚拟环境（每位开发者自建，不入库）
# ============================================================
.venv/
venv/
env/
ENV/
.python-version

# ============================================================
# 测试 / 覆盖率 / 类型检查缓存
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyre/
.ruff_cache/
.dmypy.json

# ============================================================
# 环境变量与密钥（严禁入库）
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# IDE / 编辑器
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# 日志 / 临时文件
# ============================================================
*.log
logs/
tmp/
temp/
