MUYING_AGENT_SPRING_BASE_URL=http://localhost:8080/api
MUYING_AGENT_REQUEST_TIMEOUT_SECONDS=20
MUYING_AGENT_TOOL_TIMEOUT_SECONDS=8
MUYING_AGENT_TOOL_MAX_RETRIES=1
MUYING_AGENT_ENABLE_LLM=false
MUYING_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
MUYING_AGENT_OPENAI_API_KEY=
MUYING_AGENT_OPENAI_MODEL=gpt-4o-mini

# ===== 安全 =====
# 允许跨域来源（逗号分隔）。生产必须显式配置；禁止使用 "*"。
MUYING_AGENT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
# 内网共享密钥；非空时 /api/v1/* 必须带 X-Internal-Token 请求头。
MUYING_AGENT_INTERNAL_TOKEN=
MUYING_AGENT_CHAT_RATE_LIMIT=60/minute

# ===== 上下文 =====
MUYING_AGENT_HISTORY_MAX_CHARS=262144

# ===== 日志 =====
MUYING_AGENT_LOG_LEVEL=INFO
